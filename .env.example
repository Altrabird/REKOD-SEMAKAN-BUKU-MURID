# GEMINI_API_KEY: Server-side only. Used by server.ts to proxy Gemini calls.
# Do NOT prefix with VITE_ — key must stay out of the client bundle.
GEMINI_API_KEY=""

# PORT: Express server port (default 3000).
PORT=3000

# GOOGLE SHEETS
VITE_GOOGLE_SHEETS_ID=""
VITE_GOOGLE_API_KEY=""
VITE_GOOGLE_SHEET_CSV_URL="" # Alternative: Use "Publish to Web" CSV link to avoid API Key/Billing requirements

# SUPABASE (For Evidence Storage)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
